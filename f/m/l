local function ValidateKey(userKey, isAutoCheck)
    if not isSupported then
        Notify("Error", "Game not supported by script", "Error", 4)
        return
    end

    if typeof(userKey) ~= "string" then
        Notify("Error", "Invalid key (not a string)", "Error", 4)
        return
    end

    userKey = userKey:gsub('"', ""):gsub("^%s+", ""):gsub("%s+$", "")

    if not isAutoCheck then
        RedeemText.Text = "Checking..."
        SetStatusLoading()
    end

    local success, status = pcall(function()
        return api.check_key(userKey)
    end)

    if not success then
        if StatusSpinTween then StatusSpinTween:Cancel() end
        StatusIcon.Rotation = 0
        Notify("Error", "Server Connection Failed (API)", "Error", 4)
        StatusText.Text = "Connection Error"
        StatusText.TextColor3 = Colors.NotifyError
        StatusIcon.Image = asset_mgr.get("wifi-off")
        StatusIcon.ImageColor3 = Colors.NotifyError
        
        if isAutoCheck then
            CheckStatus.Text = "Connection Failed"
            CheckStatus.TextColor3 = Colors.NotifyError
            task.wait(1)
            CheckLoader.Visible = false
            MainCard.Visible = true
        else
            task.delay(3, ResetStatus)
            RedeemText.Text = "Redeem Key"
        end
        return
    end

    if status.code == "KEY_VALID" then
        if StatusSpinTween then StatusSpinTween:Cancel() end
        StatusIcon.Rotation = 0
        
        if isAutoCheck then
            TweenService:Create(CheckBarFill, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 1, 0)}):Play()
            CheckStatus.Text = "Successfully Validated!"
            CheckStatus.TextColor3 = Colors.NotifySuccess
            task.wait(1)
            CheckLoader.Visible = false
        else
            Notify("Success", "Key Valid! Loading...", "Success", 5)
            RedeemText.Text = "Success!"
            StatusText.Text = "Access Granted!"
            StatusText.TextColor3 = Colors.NotifySuccess
            StatusIcon.Image = asset_mgr.get("check")
            StatusIcon.ImageColor3 = Colors.NotifySuccess
            MainCard.Visible = false
        end

        if writefile then
            writefile(Config.FileName, userKey)
        end

        task.spawn(function()
            getgenv().script_key = userKey
            script_key = userKey
            api.load_script()
        end)

        task.wait(5)
        if ScreenGui then ScreenGui:Destroy() end
    else
        local errorText = "Invalid Key"
        
        if status.code == "KEY_EXPIRED" then errorText = "Key Expired"
        elseif status.code == "KEY_HWID_LOCKED" then errorText = "HWID Locked"
        elseif status.code == "KEY_INCORRECT" then errorText = "Key Incorrect"
        elseif status.code == "KEY_BANNED" then errorText = "Key Blacklisted"
        elseif status.code == "KEY_INVALID" then errorText = "Invalid Format"
        end

        if isAutoCheck then
            CheckStatus.Text = errorText
            CheckStatus.TextColor3 = Colors.NotifyError
            TweenService:Create(CheckBarFill, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Colors.NotifyError}):Play()
            task.wait(2)
            CheckLoader.Visible = false
            MainCard.Visible = true
        else
            if StatusSpinTween then StatusSpinTween:Cancel() end
            StatusIcon.Rotation = 0
            RedeemText.Text = "Redeem Key"

            Notify("Error", errorText, "Error", 4)
            StatusText.Text = errorText
            StatusText.TextColor3 = Colors.NotifyError
            StatusIcon.Image = asset_mgr.get("alert-circle")
            StatusIcon.ImageColor3 = Colors.NotifyError

            local originalPos = InputFrame.Position
            for i = 1, 6 do
                local offset = (i % 2 == 0) and -5 or 5
                InputFrame.Position = originalPos + UDim2.new(0, offset, 0, 0)
                task.wait(0.05)
            end
            InputFrame.Position = originalPos
            task.delay(3, ResetStatus)
        end
    end
end

RedeemBtn.MouseButton1Click:Connect(function()
    local userKey = KeyInput.Text:gsub(" ", "")
    ValidateKey(userKey, false)
end)

task.spawn(function()
    local foundKey = nil
    if script_key and #script_key > 0 then
        foundKey = script_key
    elseif isfile and isfile(Config.FileName) then
        local content = readfile(Config.FileName)
        if content and #content > 0 then
            foundKey = content
        end
    end

    if foundKey and #foundKey > 0 then
        CheckLoader.Visible = true
        MainCard.Visible = false
        CheckStatus.Text = "Found Saved Key! Validating..."
        TweenService:Create(CheckBarFill, TweenInfo.new(1, Enum.EasingStyle.Linear), {Size = UDim2.new(0.5, 0, 1, 0)}):Play()
        task.wait(0.5)
        ValidateKey(foundKey, true)
    else
        CheckLoader.Visible = false
        MainCard.Visible = true
    end
end)
